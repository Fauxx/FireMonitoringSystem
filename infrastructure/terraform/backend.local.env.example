# Local Terraform backend contract (copy to backend.local.env and fill secrets)
# This file keeps local first-run behavior aligned with CI/CD terraform-contract.

# Workspace + key defaults (non-secret, deterministic)
TF_WORKSPACE=local
TF_STATE_KEY_PREFIX=terraform/fire-monitoring
# Optional init mode:
# - bootstrap (default): initialize/reconfigure backend and create/select workspace
# - migrate: migrate existing local workspace state to remote backend once
# TF_INIT_MODE=bootstrap

# Required remote backend config (S3-compatible / DigitalOcean Spaces)
TF_STATE_BUCKET=
TF_STATE_REGION=us-east-1
TF_STATE_ENDPOINT=
TF_STATE_ACCESS_KEY=
TF_STATE_SECRET_KEY=

# Optional explicit backend key override.
# If empty, key resolves to: ${TF_STATE_KEY_PREFIX}/${TF_WORKSPACE}.tfstate
# TF_BACKEND_KEY=
