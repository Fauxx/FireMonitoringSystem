
POSTGRES_USER=fireuser
POSTGRES_PASSWORD=local-password
POSTGRES_DB=fire_monitoring
POSTGRES_HOST=db
POSTGRES_PORT=5432
PGSSLMODE=disable

# Connection string used by API, ETL, etc.
DATABASE_URL=postgresql://fireuser:local-password@db:5432/fire_monitoring

# InfluxDB 2.x
INFLUXDB_INIT_MODE=setup
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword123
INFLUXDB_URL=http://influx:8086
INFLUXDB_TOKEN=local-influx-token
INFLUXDB_ORG=fire-monitoring
INFLUXDB_BUCKET=sensor-data
INFLUXDB_CLI_CONFIG_NAME=firedev
INFLUX_MEASUREMENT=fire_data

# MQTT (for API & dashboard; simulator uses MQTT_HOST/MQTT_PORT)
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883

# ETL Settings
ETL_SYNC_INTERVAL=30
AGG_WINDOW_MINUTES=5


# Threshold Tuning (Can be changed live in Prod)
THRESHOLD_SMOKE_ORANGE=100
THRESHOLD_SMOKE_RED=250
THRESHOLD_TEMP_ORANGE=38.0
THRESHOLD_TEMP_RED=45.0

# Image defaults (used by docker-compose-prod.yml)
IMAGE_REGISTRY=local
IMAGE_TAG=latest
