# Core application
NODE_ENV=development
PORT=8000
SESSION_SECRET=change-this-secret-key

# PostgreSQL
POSTGRES_DB=fire_monitoring
POSTGRES_USER=fireuser
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://fireuser:changeme@postgres:5432/fire_monitoring

# External RDS placeholder
RDS_HOST=rds.example.com
RDS_PORT=5432
RDS_DB=fire_monitoring
RDS_USER=fireuser
RDS_PASSWORD=changeme

# InfluxDB 2.x bootstrap
INFLUXDB_INIT_MODE=setup
INFLUXDB_USERNAME=fireops
INFLUXDB_PASSWORD=changeme
INFLUXDB_ORG=fire-monitoring
INFLUXDB_BUCKET=sensor-data
INFLUXDB_TOKEN=influx-token

# Telegraf / MQTT
MQTT_BROKER_HOST=mqtt-broker
MQTT_BROKER_PORT=1883
INFLUX_TOKEN=influx-token

# Grafana (optional overrides)
GF_SECURITY_ADMIN_PASSWORD=admin

# Misc services
LOCAL_PORT=8001

