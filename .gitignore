# =================================================================
# 1. SYSTEM & IDE (The "Personal" stuff)
# =================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.bak

# =================================================================
# 2. ENVIRONMENT & SECRETS (CRITICAL: Do not push these!)
# =================================================================
.env
.env.*
!.env.example
secrets.txt

# =================================================================
# 3. NODE.JS / DASHBOARD (The "Web" layer)
# =================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
.npm
dist/
build/
.cache/

# =================================================================
# 4. PYTHON / ETL (The "Data" layer)
# =================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/
.mypy_cache/

# =================================================================
# 5. INFRASTRUCTURE & PERSISTENT DATA
# =================================================================
# Ignore actual database files but keep the directory structure
infrastructure/mqtt/data/*
infrastructure/mqtt/log/*
infrastructure/influxdb/data/*
infrastructure/influxdb/config/*
postgres_data/

# Allow git to keep the directories but ignore the content
!infrastructure/mqtt/data/.gitkeep
!infrastructure/mqtt/log/.gitkeep

# =================================================================
# 6. DOCKER & LOGS
# =================================================================
api/logs/
*.log
.docker/